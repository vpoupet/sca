{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SCA",
  "scopeName": "source.sca",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#beginFunction"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#multiSignals"
    },
    {
      "include": "#prefixedAtoms"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#brackets"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#signals"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.sca",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sca",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sca",
              "match": "\\\\[\"\\\\]"
            }
          ]
        }
      ]
    },
    "beginFunction": {
      "patterns": [
        {
          "match": "(@begin)(\\s+)([a-zA-Z_$][a-zA-Z_$0-9\\-\\u2192,/]*)",
          "captures": {
            "1": {
              "name": "keyword.control.directive.sca"
            },
            "3": {
              "name": "entity.name.function.sca"
            }
          }
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.sca",
          "match": "@(?:begin|end)\\b"
        }
      ]
    },
    "multiSignals": {
      "patterns": [
        {
          "match": "^(\\s*)([a-zA-Z_$][a-zA-Z_$0-9\\-\\u2192,/]*)(\\s*)(=)",
          "captures": {
            "2": {
              "name": "entity.name.constant.sca"
            },
            "4": {
              "name": "keyword.operator.assignment.sca"
            }
          }
        }
      ]
    },
    "prefixedAtoms": {
      "patterns": [
        {
          "match": "([+-]?[0-9]+(?:,[+-]?[0-9]+)*(?:/[+-]?[0-9]+)?|/[+-]?[0-9]+)(\\.)(!?)\\s*([a-zA-Z_$][a-zA-Z_$0-9\\-\\u2192,/]*)",
          "captures": {
            "1": {
              "name": "constant.numeric.position.sca"
            },
            "2": {
              "name": "punctuation.accessor.dot.sca"
            },
            "3": {
              "name": "keyword.operator.logical.not.sca"
            },
            "4": {
              "name": "entity.name.type.signal.sca"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.not.sca",
          "match": "!"
        },
        {
          "name": "keyword.operator.time-step.sca",
          "match": "/"
        },
        {
          "name": "keyword.operator.assignment.sca",
          "match": "="
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.sca",
          "match": "[+-]?[0-9]+"
        }
      ]
    },
    "brackets": {
      "patterns": [
        {
          "name": "punctuation.definition.group.sca",
          "match": "[()\\[\\]{}]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.sca",
          "match": "[:,.]"
        }
      ]
    },
    "signals": {
      "patterns": [
        {
          "name": "entity.name.type.signal.sca",
          "match": "[a-zA-Z_$][a-zA-Z_$0-9\\-\\u2192,/]*"
        }
      ]
    }
  }
}
